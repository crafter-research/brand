---
import Layout from "../layouts/Layout.astro";
import { CRAFTER_MARK_PATH, CRAFTER_MARK_VIEWBOX, colors } from "../lib/brand";

const prompts = [
  {
    label: "Hero Field",
    size: "16:9",
    prompt:
      "Cinematic minimal research lab scene for Crafter Research, obsidian green table, legal corpus pages, glass evidence panels, subtle mint signal light, precise public-interest research atmosphere, no people, no text, no logo, no fake dashboard, premium but quiet.",
  },
  {
    label: "Corpus Card",
    size: "1:1",
    prompt:
      "Minimal square brand asset for Crafter Research, archival legal documents under translucent graphite glass, source pins, corpus index tabs, muted paper white and research green palette, evidence-first lab mood, no text, no logo, no people.",
  },
  {
    label: "Agent Trace",
    size: "4:5",
    prompt:
      "Vertical editorial asset for Crafter Research showing an inspectable agent trace, source fragments, evaluation marks, small green signal lines, physical lab materials, calm technical precision, no UI hallucinations, no text, no logo.",
  },
  {
    label: "Launch Plate",
    size: "1200 x 630",
    prompt:
      "Open graph image background for Crafter Research, dark research bench, single evidence sheet, subtle corpus grid, mint reflection, source-verification mood, lots of negative space for small wordmark, no embedded text, no logo.",
  },
];

const exports = [
  ["Open graph", "1200 x 630", "/og.png"],
  ["Hero image", "2400 x 1350", "/gen/lab-hero.png"],
  ["Application square", "1600 x 1600", "/gen/lab-applications.png"],
  ["App icon", "1024 x 1024", "/favicon.svg"],
];

const rules = [
  "Use the official Crafter mark only.",
  "Keep source material visible.",
  "Leave open space for method lines.",
  "Prefer one strong asset over a collage.",
  "Avoid mascots, neon dashboards, gold, and generic AI glow.",
];
---
<Layout
  title="Generate Assets | Crafter Research Brand"
  description="Minimal asset generation kit for Crafter Research brand imagery, prompts, tokens, and export sizes."
  url="https://brand.crafter.ing/generate-assets"
>
  <div class="site-shell asset-page">
    <header class="topbar" aria-label="Asset generator header">
      <a class="brand-lockup" href="/" aria-label="Crafter Research brand home">
        <svg viewBox={CRAFTER_MARK_VIEWBOX} aria-hidden="true">
          <path d={CRAFTER_MARK_PATH}></path>
        </svg>
        <span>Crafter Research</span>
      </a>
      <nav aria-label="Asset generator sections">
        <a href="/"><span>00</span>Brand</a>
        <a href="#prompts"><span>01</span>Prompts</a>
        <a href="#tokens"><span>02</span>Tokens</a>
        <a href="#exports"><span>03</span>Exports</a>
      </nav>
      <aside aria-label="Theme mode">
        <button class="theme-toggle" type="button" data-theme-toggle aria-label="Theme mode">
          System
        </button>
      </aside>
    </header>

    <main>
      <section class="asset-hero section-frame" aria-labelledby="asset-title">
        <div class="asset-hero-copy">
          <p class="mono-label">Asset generator</p>
          <h1 id="asset-title">Quiet assets for a working lab.</h1>
          <p>
            Prompt set, export sizes, and visual constraints for Crafter Research.
            Minimal by default, evidence visible, no invented interface theater.
          </p>
        </div>
        <div class="asset-hero-mark" aria-hidden="true">
          <svg viewBox={CRAFTER_MARK_VIEWBOX}>
            <path d={CRAFTER_MARK_PATH}></path>
          </svg>
          <span>research.build.advance</span>
        </div>
      </section>

      <section id="prompts" class="asset-section section-frame">
        <div class="asset-section-heading">
          <span>01</span>
          <h2>Prompt Set</h2>
        </div>
        <div class="prompt-grid">
          {prompts.map((item) => (
            <article class="prompt-card">
              <div>
                <p>{item.size}</p>
                <h3>{item.label}</h3>
              </div>
              <pre>{item.prompt}</pre>
              <button type="button" data-copy={item.prompt}>Copy prompt</button>
            </article>
          ))}
        </div>
      </section>

      <section id="tokens" class="asset-section section-frame">
        <div class="asset-section-heading">
          <span>02</span>
          <h2>Brand Tokens</h2>
        </div>
        <div class="token-board">
          <div class="token-mark">
            <svg viewBox={CRAFTER_MARK_VIEWBOX} aria-label="Crafter Research mark">
              <path d={CRAFTER_MARK_PATH}></path>
            </svg>
          </div>
          <div class="token-list">
            {colors.map((color) => (
              <article style={`--swatch:${color.hex}`}>
                <span></span>
                <div>
                  <h3>{color.name}</h3>
                  <p>{color.hex}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="exports" class="asset-section section-frame">
        <div class="asset-section-heading">
          <span>03</span>
          <h2>Exports</h2>
        </div>
        <div class="export-grid">
          {exports.map(([name, size, href]) => (
            <a href={href} target="_blank" rel="noreferrer">
              <span>{size}</span>
              <strong>{name}</strong>
              <small>{href}</small>
            </a>
          ))}
        </div>
        <ul class="asset-rules">
          {rules.map((rule) => <li>{rule}</li>)}
        </ul>
      </section>
    </main>
  </div>

  <script>
    for (const button of document.querySelectorAll("[data-copy]")) {
      button.addEventListener("click", async () => {
        const text = button.getAttribute("data-copy") ?? "";
        await navigator.clipboard.writeText(text);
        button.textContent = "Copied";
        window.setTimeout(() => {
          button.textContent = "Copy prompt";
        }, 1300);
      });
    }
  </script>
</Layout>
