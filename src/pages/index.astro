---
import Layout from "../layouts/Layout.astro";
import { CRAFTER_MARK_PATH, CRAFTER_MARK_VIEWBOX, colors } from "../lib/brand";

const nav = [
  ["00", "Brand", "#top"],
  ["01", "Mark", "#mark"],
  ["02", "Color", "#color"],
  ["03", "Type", "#type"],
  ["04", "Applications", "#applications"],
  ["05", "Imagery", "#imagery"],
  ["06", "Voice", "#voice"],
  ["07", "Social", "#social"],
  ["+", "Assets", "/generate-assets"],
];

const markModes = [
  ["Primary", "Filled green mark for interfaces, reports, and public surfaces."],
  ["Outline", "Single-line mark for diagrams, system maps, and construction notes."],
  ["Clear space", "Use one mark width on every side before adding text or rules."],
  ["Stamp", "Small evidence stamp for source exports and corpus records."],
];

const applicationRules = [
  ["Research reports", "Lead with question, method, sources, and limits before claims."],
  ["Corpus explorers", "Use diagrams to expose indexing, provenance, and source joins."],
  ["Agent evaluations", "Show harness inputs, trace outputs, review status, and failure cases."],
  ["Public records exports", "Package manifest, sources, artifacts, signatures, and dates together."],
];

const voicePairs = [
  ["We say", "Here is the corpus, the method, the trace, and the limit."],
  ["We say", "Inspectable systems for public-interest research."],
  ["We avoid", "Magic AI, vague intelligence, and claims without evidence."],
  ["We avoid", "Decorative dashboards that hide how the answer was produced."],
];

const socialFrames = [
  ["Open graph", "1200 x 630", "Research systems for inspectable evidence."],
  ["Launch plate", "1 x 1", "Corpus, agents, evaluations, and public records."],
  ["Report header", "16 x 9", "Every claim links to a source."],
];
---
<Layout
  title="Crafter Research Brand"
  description="Brand system for Crafter Research, a lab for inspectable research systems, corpora, agents, and evidence trails."
>
  <div class="manual-shell">
    <header class="manual-topbar" aria-label="Crafter Research manual header">
      <a class="manual-lockup" href="#top" aria-label="Crafter Research brand">
        <svg viewBox={CRAFTER_MARK_VIEWBOX} aria-hidden="true">
          <path d={CRAFTER_MARK_PATH}></path>
        </svg>
        <span>Crafter Research</span>
      </a>
      <nav aria-label="Brand sections">
        {nav.map(([num, label, href]) => (
          <a href={href}><span>{num}</span>{label}</a>
        ))}
      </nav>
      <aside aria-label="Manual identifier">
        <div>
          <strong>brand.crafter.ing</strong>
          <span>REF MANUAL v1.1</span>
        </div>
        <button class="theme-toggle" type="button" data-theme-toggle aria-label="Theme mode">
          System
        </button>
      </aside>
    </header>

    <main id="top">
      <section class="manual-hero" aria-labelledby="cover-title">
        <div class="hero-copy">
          <p class="figure-label">FIG-001</p>
          <h1 id="cover-title">Crafter Research</h1>
          <p class="hero-line">Research systems for inspectable evidence.</p>
          <p class="hero-intro">
            We assemble corpora, design agents, run evaluations, and publish
            evidence trails that can be inspected, reproduced, and challenged.
          </p>
          <dl class="hero-meta">
            <div><dt>Lab</dt><dd>Crafter Research</dd></div>
            <div><dt>Domain</dt><dd>brand.crafter.ing</dd></div>
            <div><dt>Mode</dt><dd>Public-interest infrastructure</dd></div>
            <div><dt>Updated</dt><dd>2026-06-16</dd></div>
          </dl>
          <div class="manual-actions" aria-label="Primary brand references">
            <a href="#mark">Use the mark</a>
            <a href="/generate-assets">Generate assets</a>
          </div>
        </div>

        <div class="hero-diagram" aria-label="Crafter Research exploded system diagram">
          <span class="side-note">EXPLODED SYSTEM VIEW</span>
          <div class="annotation-list">
            <div class="annotation annotation-1">
              <strong>CRAFTER MARK</strong>
              <span>Identity anchor for the lab.</span>
            </div>
            <div class="annotation annotation-2">
              <strong>CORPUS LAYER</strong>
              <span>Curated collections of primary sources.</span>
            </div>
            <div class="annotation annotation-3">
              <strong>SOURCE TRACE</strong>
              <span>Every claim links to a source.</span>
            </div>
            <div class="annotation annotation-4">
              <strong>AGENT HARNESS</strong>
              <span>Agents act, log, and explain.</span>
            </div>
            <div class="annotation annotation-5">
              <strong>VERIFICATION</strong>
              <span>Evaluations, reviews, and public records.</span>
            </div>
          </div>
          <img src="/gen/research-system-manual.png" alt="Exploded research system illustration with corpus, trace, harness, and verification layers" decoding="async" />
        </div>
      </section>

      <section id="mark" class="manual-section mark-section">
        <div class="section-index">
          <span>FIG-002</span>
          <h2>01 Mark</h2>
          <p>
            The mark behaves like an engineering artifact: exact, reproducible,
            and useful at interface scale.
          </p>
        </div>
        <div class="mark-specimens">
          {markModes.map(([title, body], index) => (
            <article class={`mark-card mark-card-${index + 1}`}>
              <span>{title}</span>
              <div>
                <svg viewBox={CRAFTER_MARK_VIEWBOX} aria-hidden="true">
                  <path d={CRAFTER_MARK_PATH}></path>
                </svg>
              </div>
              <p>{body}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="color" class="manual-section color-section">
        <div class="section-index">
          <span>FIG-003</span>
          <h2>02 Color</h2>
          <p>
            A restrained system built for legibility and technical calm.
            Research green is the primary signal across diagrams, labels, and interfaces.
          </p>
        </div>
        <div class="swatch-grid">
          {colors.map((color) => (
            <article class="swatch" style={`--swatch:${color.hex}`}>
              <div></div>
              <h3>{color.name}</h3>
              <p>{color.token}</p>
              <code>{color.hex}</code>
            </article>
          ))}
        </div>
      </section>

      <section id="type" class="manual-section type-section">
        <div class="section-index">
          <span>FIG-004</span>
          <h2>03 Type</h2>
          <p>
            Editorial serif for argument and explanation. Mono for labels,
            IDs, source references, dates, and system state.
          </p>
        </div>
        <div class="type-plate">
          <article>
            <span>Serif - editorial</span>
            <strong>Sources before claims.</strong>
            <p>Aa Bb Cc Dd Ee Ff Gg Hh Ii Jj Kk Ll Mm Nn Oo Pp 0123456789</p>
          </article>
          <article>
            <span>Mono - technical</span>
            <strong>CR-TRACE/PE/2026</strong>
            <p>LAW.CORPUS/PE - SOURCE VERIFIED - EVAL HARNESS READY</p>
          </article>
        </div>
      </section>

      <section id="applications" class="manual-section applications-section">
        <div class="section-index">
          <span>FIG-005</span>
          <h2>04 Applications</h2>
          <p>
            The system appears in products and documents where the work must
            show its sources, constraints, and verification path.
          </p>
        </div>
        <div class="application-grid">
          {applicationRules.map(([title, body], index) => (
            <article>
              <span>{index + 1}</span>
              <strong>{title}</strong>
              <p>{body}</p>
              <div class="manual-rule" aria-hidden="true"></div>
            </article>
          ))}
        </div>
      </section>

      <section id="imagery" class="manual-section imagery-section">
        <div class="section-index">
          <span>FIG-006</span>
          <h2>05 Imagery</h2>
          <p>
            Visuals should reveal apparatus: documents, trace graphs, evaluation
            tables, public record packages, and system diagrams.
          </p>
        </div>
        <figure class="image-plate">
          <img src="/gen/research-system-manual.png" alt="Technical manual illustration of the Crafter Research apparatus" loading="lazy" decoding="async" />
          <figcaption>
            <span>Generated manual plate</span>
            <p>Use diagrammatic imagery when source material and method need to stay visible.</p>
          </figcaption>
        </figure>
      </section>

      <section id="voice" class="manual-section voice-section">
        <div class="section-index">
          <span>FIG-007</span>
          <h2>06 Voice</h2>
          <p>
            Direct, method-led, bilingual when useful, and strict about what can
            be inspected.
          </p>
        </div>
        <div class="voice-grid">
          {voicePairs.map(([label, text]) => (
            <article class={label === "We avoid" ? "avoid" : "say"}>
              <span>{label}</span>
              <p>{text}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="social" class="manual-section social-section">
        <div class="section-index">
          <span>FIG-008</span>
          <h2>07 Social</h2>
          <p>
            Export frames stay spare: mark, domain, method line, and one visual
            field. Short enough to cite.
          </p>
        </div>
        <div class="social-grid">
          {socialFrames.map(([title, size, text]) => (
            <article>
              <span>{size}</span>
              <strong>{title}</strong>
              <p>{text}</p>
              <svg viewBox={CRAFTER_MARK_VIEWBOX} aria-hidden="true">
                <path d={CRAFTER_MARK_PATH}></path>
              </svg>
            </article>
          ))}
        </div>
      </section>
    </main>

    <footer class="manual-footer">
      <div>
        <svg viewBox={CRAFTER_MARK_VIEWBOX} aria-hidden="true">
          <path d={CRAFTER_MARK_PATH}></path>
        </svg>
        <strong>Crafter Research</strong>
      </div>
      <nav aria-label="Footer resources">
        <a href="#top">Manual top</a>
        <a href="/generate-assets">Asset generator</a>
        <a href="https://github.com/crafter-research/brand">GitHub</a>
      </nav>
      <aside>
        <span>MANUAL ID</span>
        <strong>CR-BRAND-1.1</strong>
      </aside>
    </footer>
  </div>

</Layout>
